{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "strict": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "public",
    "rootDir": "public",
    "noEmitOnError": false,
    "types": []
  },
  "include": ["public/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
